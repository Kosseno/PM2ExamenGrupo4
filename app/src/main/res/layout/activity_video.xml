<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".video">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:layout_editor_absoluteX="138dp"
        tools:layout_editor_absoluteY="73dp"
        tools:srcCompat="@tools:sample/avatars" />

    <Button
        android:id="@+id/btntomarvideo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tomar Video"
        tools:layout_editor_absoluteX="136dp"
        tools:layout_editor_absoluteY="220dp" />

    <EditText
        android:id="@+id/txtnombre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Nombre"
        android:inputType="text"
        tools:layout_editor_absoluteX="102dp"
        tools:layout_editor_absoluteY="283dp" />

    <EditText
        android:id="@+id/txttelefono"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Telefono"
        android:inputType="text"
        tools:layout_editor_absoluteX="105dp"
        tools:layout_editor_absoluteY="343dp" />

    <EditText
        android:id="@+id/txtlatitud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Latitud"
        android:inputType="text"
        tools:layout_editor_absoluteX="105dp"
        tools:layout_editor_absoluteY="405dp" />

    <EditText
        android:id="@+id/txtlongitud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:hint="Longitud"
        android:inputType="text"
        tools:layout_editor_absoluteX="105dp"
        tools:layout_editor_absoluteY="468dp" />

    <Button
        android:id="@+id/btnsalvarcontacto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Salvar Contacto"
        tools:layout_editor_absoluteX="153dp"
        tools:layout_editor_absoluteY="532dp" />

    <Button
        android:id="@+id/btncontactossalvados"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Contactos Salvados"
        tools:layout_editor_absoluteX="128dp"
        tools:layout_editor_absoluteY="601dp" />
</androidx.constraintlayout.widget.ConstraintLayout>